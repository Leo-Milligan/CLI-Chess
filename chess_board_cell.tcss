MainMenu {
    align: center middle;
    hatch: right $surface;
}

#main_menu_grid {
    grid-size: 1;
    grid-gutter: 1 2;
    grid-rows: 1fr 3 5;
    padding: 0 4;
    width: 83;
    height: 22;
    border: round white;
    border-title-align: center;
    background: $panel;
}

#title {
    column-span: 2;
    height: 1fr;
    width: 1fr;
    content-align: center middle;
    margin-bottom: 2;
}

.cell {
    width: 1fr;
    height: 1fr;
    content-align: center middle;
}

#game_grid {
    grid-size: 2 2;
    grid-rows: 1fr 2;
    grid-columns: 4fr 1fr
}

#white_captured_pieces_display {
    height: 1;
    width: 100%;
    background: $panel;
}

ChessBoardWithAccessories {
    margin: 1 2;
}

#black_captured_pieces_display {
    height: 1;
    width: 100%;
    background: $panel;
}

MoveDataTable {
    margin: 1 2;
    height: 100%;
}

StatusBar {
    column-span: 2;
    background: $surface;
}

#message_line {
    height: auto;
    width: auto;
}

GameOverScreen {
    align: center middle;
}

#dialog {
    grid-size: 3;
    grid-gutter: 1 2;
    grid-rows: 1fr 3;
    padding: 0 1;
    width: 60;
    height: 11;
    border: thick $background 80%;
    background: $surface;
}

#message {
    column-span: 3;
    height: 1fr;
    width: 1fr;
    content-align: center middle;
}

Button {
    width: 100%;
}
